# Custom Dockerfile for Open WebUI with Lorica integration
FROM ghcr.io/open-webui/open-webui:main

# Copy our built frontend with Lorica integration
COPY build/ /app/static/

# Set the correct permissions
RUN chown -R 1000:1000 /app/static/

# Expose the port
EXPOSE 8080

# Use the same entrypoint as the original image
CMD ["bash", "start.sh"]
